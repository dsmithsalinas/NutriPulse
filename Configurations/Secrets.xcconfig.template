// ─────────────────────────────────────────────────────────────
// Copy this file to Configurations/Secrets.xcconfig
// and fill in your NutriPulse Supabase project values.
//
// Secrets.xcconfig is listed in .gitignore — NEVER commit it.
// ─────────────────────────────────────────────────────────────

// xcconfig treats // as a comment — use the SLASH trick for URLs.
SLASH = /
SUPABASE_URL = https:$(SLASH)$(SLASH)your-project-id.supabase.co
SUPABASE_ANON_KEY = your-anon-key-here
